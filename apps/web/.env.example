# Supabase (get these from your Supabase project dashboard or `npx supabase start`)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# API URL (where the Hono API is running)
NEXT_PUBLIC_API_URL=http://localhost:8787

# App URL (used for metadata and redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Tenant slug — required for single-domain deployments (baked in at build time)
NEXT_PUBLIC_TENANT_SLUG=dev

# E2E test credentials (never commit real values)
# E2E_EMAIL=your-test-user@example.com
# E2E_PASSWORD=your-test-password
# E2E_ADMIN_EMAIL=your-admin@example.com
# E2E_ADMIN_PASSWORD=your-admin-password
